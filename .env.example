# ─────────────────────────────────────────────
# Telegram API credentials
# Get these from https://my.telegram.org/apps
# ─────────────────────────────────────────────
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# ─────────────────────────────────────────────
# Your personal output channels
# Use @username format or numeric chat ID
# e.g. MY_CHANNEL_1=@mycryptosignals
# ─────────────────────────────────────────────
MY_CHANNEL_1=@your_channel_1
MY_CHANNEL_2=@your_channel_2

# ─────────────────────────────────────────────
# Source channels to monitor (comma-separated)
# e.g. SOURCE_CHANNELS=@channel1,@channel2,@channel3
# ─────────────────────────────────────────────
SOURCE_CHANNELS=@source_channel_1,@source_channel_2,@source_channel_3
